{
  "name": "torrentgalaxy2",
  "language": ["hi", "en"],
  "domains": ["torrentgalaxy.space", "torrentgalaxy.one"],
  "base_url": "https://torrentgalaxy.space",
  "search_url_format_episode": {
    "string_format": "/get-posts/keywords:%s+s%02de%02d?page=1",
    "replacement": ["title_lower", "season_int", "episode_int"]
  },
  "search_url_format_movie": {
    "string_format": "/get-posts/keywords:%s+%04d?page=1",
    "replacement": ["title_lower", "year_int"]
  },
  "search_url_format_season_pack": {
    "string_format": "/get-posts/keywords:%s?page=1",
    "replacement": ["title_lower"]
  },
  "check_title_before_drill_down": true,
  "drill_down_title_check_attr": "|HTML|",
  "links_on_first_page": false,
  "drill_down_path": "div.tgxtablecell.clickable-row a",
  "drill_down_path_attr": "abs:href",
  "is_torrent": true,
  "is_direct": false,
  "links_container_path": "div.tgxtablerow",
  "title_path": "div.tgxtablecell:nth-child(4) a",
  "title_path_attr": "",
  "details_path": "|title_path|",
  "details_path_attr": "",
  "magnet_path": "div.tgxtablecell:nth-child(5) a[href^=magnet]",
  "magnet_path_attr": "href",
  "seeders_path": "div.tgxtablecell:nth-child(11)",
  "seeders_path_attr": "",
  "filesize_path": "div.tgxtablecell:nth-child(8)",
  "filesize_path_attr": "",
  "quality_path": "|title_path|",
  "quality_path_attr": "",
  "info_path": "|title_path|",
  "info_path_attr": ""
}
