{
    "name": "7movierulz",
    "language": ["hi", "en"],
    "domains": ["rapidmoviez.be", "7movierulz.li"],
    "base_url": "https://www.7movierulz.app",
    "search_url_format_episode": {
        "string_format": "/search?keyword=%s+S%02dE%02d",
        "replacement": ["title", "season_int", "episode_int"]
    },
    "search_url_format_movie": {
        "string_format": "/search?keyword=%s+%04d",
        "replacement": ["title_lower", "year_int"]
    },
    "search_url_format_season_pack": {
        "string_format": "/search?keyword=%s+S%02d",
        "replacement": ["title", "season_int"]
    },
    "more_pages_indicator": "",
    "next_page_path": "",
    "next_page_path_attr": "",
    "links_on_first_page": false,
    "drill_down_path": "div.boxed.film a",
    "drill_down_path_attr": "href",
    "is_torrent": true,
    "is_direct": false,
    "links_container_path": "a[href^=magnet]",
    "link_path": "",
    "link_path_attr": "",
    "title_path": "/h2.entry-title",
    "title_path_attr": "",
    "details_path": "|title_path|",
    "details_path_attr": "",
    "magnet_path": "a[href^=magnet]",
    "magnet_path_attr": "href",
    "seeders_path": "",
    "seeders_path_attr": "",
    "filesize_path": "",
    "filesize_path_attr": "title",
    "quality_path": "",
    "quality_path_attr": "title",
    "info_path": "|title_path|",
    "info_path_attr": ""
}
