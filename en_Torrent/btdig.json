{
  "name": "Tt2NZ",
  "language": ["hi", "en"],
  "domains": ["torrentz2.nz"],
  "base_url": "https://torrentz2.nz",
  "search_url_format_episode": {
    "string_format": "/search?q=%s+s%02de%02d",
    "replacement": ["title", "season_int", "episode_int"]
  },
  "search_url_format_movie": {
    "string_format": "/search?q=%s+%04d",
    "replacement": ["title", "year_int"]
  },
  "search_url_format_season_pack": {
    "string_format": "/search?q=%s+s%02d",
    "replacement": ["title", "season_int"]
  },
  "more_pages_indicator": "a[rel='next']",
  "next_page_path": "a[rel='next']",
  "next_page_path_attr": "href",
  "links_on_first_page": false,
  "drill_down_path": "dt a",
  "drill_down_path_attr": "href",
  "is_torrent": true,
  "is_direct": false,
  "links_container_path": "dl dt",
  "link_path": "",
  "link_path_attr": "",
  "title_path": "/h2",
  "title_path_attr": "",
  "details_path": "|title_path|",
  "details_path_attr": "",
  "magnet_path": "a[href^='magnet']", 
  "magnet_path_attr": "href",
  "seeders_path": "tr:contains(Seeds) td:eq(1)",
  "seeders_path_attr": "",
  "filesize_path": "tr:contains(Size) td:eq(1)",
  "filesize_path_attr": "",
  "quality_path": "|title_path|",
  "quality_path_attr": "",
  "info_path": "|title_path|",
  "info_path_attr": ""
}
