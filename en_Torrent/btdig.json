{
  "name": "torrentgalaxy5",
  "language": ["hi", "en"],
  "domains": ["torrentgalaxy.info", "torrentgalaxy.one", "torrentgalaxy.unblockedfor.me"],
  "base_url": "https://torrentgalaxy.space",
  "search_url_format_episode": {
    "string_format": "/get-posts/keywords:%s+s%02de%02d?page=1",
    "replacement": [
      "title_lower",
      "season_int",
      "episode_int"
    ]
  },
  "search_url_format_movie": {
    "string_format": "/get-posts/keywords:%s+%04d?page=1",
    "replacement": [
      "title_lower",
      "year_int"
    ]
  },
  "search_url_format_season_pack": {
    "string_format": "/get-posts/keywords:%s?page=1",
    "replacement": [
      "title_lower"
    ]
  },
  "more_pages_indicator": "",
  "next_page_path": "",
  "next_page_path_attr": "",
  "links_on_first_page": false,
  "drill_down_path": "div.tgxtablerow div.tgxtablecell:eq(4) a[href^=/post-detail/]",
  "drill_down_path_attr": "href",
  "is_torrent": true,
  "is_direct": false,  
  "links_container_path": "div.gluewrapper",
  "title_path": "div.clickable-row.click.textshadow.rounded.txlight a span b",
  "title_path_attr": "",
  "details_path": "|title_path|",
  "details_path_attr": "",
  "magnet_path": "div.tpcell a[href^='magnet:']",
  "magnet_path_attr": "href",
  "seeders_path": "div.torrentpagetable.limitwidth div.tprow:contains(Stats:) button.btn-success span.badge",
  "seeders_path_attr": "",
  "filesize_path": "div.torrentpagetable.limitwidth div.tprow:contains(Total Size:) div.tpcell:eq(1)",
  "filesize_path_attr": "",
  "quality_path": "|title_path|",
  "quality_path_attr": "",
  "info_path": "div.torrentpagetable.limitwidth",
  "info_path_attr": ""
}
